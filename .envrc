#!/usr/bin/env bash
# direnv configuration for jacaranda-pihole
#
# Automatically activates mise and Python virtual environment.
# Load secrets from .envrc.secrets if present.

# Load mise (manages tool versions)
if command -v mise &> /dev/null; then
    eval "$(mise activate bash)"
    eval "$(mise hook-env)"
fi

# Activate Python virtual environment
layout python python3.12

# Load secrets (gitignored)
if [ -f .envrc.secrets ]; then
    source .envrc.secrets
fi

# Add scripts to PATH
PATH_add scripts
