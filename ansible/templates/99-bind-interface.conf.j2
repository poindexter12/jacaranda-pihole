# Pi-hole DNS Binding Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY
#
# Configures dnsmasq interface binding for Pi-hole FTL v6 with listeningMode=NONE
# This allows multiple Pi-hole instances on the same VM (different interfaces/IPs)

# Bind to specific interface only (dns-std or dns-res dummy interface)
interface={{ dns_interface }}

# Force strict binding to the specified interface (no wildcard binding)
bind-interfaces

# Explicitly NOT binding to localhost - prevents port 53 conflicts between profiles
# Note: except-interface is used to exclude lo even if it was auto-added
except-interface=lo
