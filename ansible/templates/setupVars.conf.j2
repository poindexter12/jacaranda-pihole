# Pi-hole Unattended Installation Configuration
# Generated by Ansible for {{ inventory_hostname }}
# Profile: {{ profile }} | Role: {{ role }}

# Network interface (FTL v6 binds to interface name, not IP)
PIHOLE_INTERFACE=eth0

# DNS IP address (informational - FTL uses interface binding)
IPV4_ADDRESS={{ dns_ip }}/24

# IPv6 disabled
IPV6_ADDRESS=

# Upstream DNS servers
{% for dns in dns_upstream[profile] %}
PIHOLE_DNS_{{ loop.index }}={{ dns }}
{% endfor %}

# Query logging
QUERY_LOGGING=true

# Web admin interface
INSTALL_WEB_SERVER=true
INSTALL_WEB_INTERFACE=true
LIGHTTPD_ENABLED=false

# Blocking mode (NULL = return 0.0.0.0 for blocked domains)
BLOCKING_ENABLED=true
BLOCKINGMODE=NULL

# Privacy level (0=show everything)
PRIVACYLEVEL=0

# DNS settings
CACHE_SIZE=10000
DNS_FQDN_REQUIRED=true
DNS_BOGUS_PRIV=true
DNSSEC=false
REV_SERVER=false

# Web password hash (set via pihole -a -p after install)
WEBPASSWORD=
