# nebula-sync configuration for {{ inventory_hostname }}
# Generated by Ansible
# Profile: {{ profile }} | Role: {{ role }}
# Syncs FROM: {{ sync_partner }} ({{ sync_partner_transfer_ip }}) over transfer network

# Primary Pi-hole (source to sync FROM) - uses transfer network (192.168.11.x)
PRIMARY=http://{{ sync_partner_transfer_ip }}|{{ pihole_password }}

# Replica Pi-hole (this instance, target to sync TO) - uses transfer network
REPLICAS=http://{{ transfer_ip }}|{{ pihole_password }}

# Sync options
FULL_SYNC=true
RUN_GRAVITY=true

# Timezone
TZ=America/Los_Angeles
