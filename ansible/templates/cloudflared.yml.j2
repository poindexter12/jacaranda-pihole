# Cloudflared DNS-over-HTTPS Proxy Configuration
# Generated by Ansible for {{ inventory_hostname }}
# Profile: {{ profile }}
#
# Pi-hole queries this proxy on 127.0.0.1:{{ cloudflared_port }}
# Cloudflared forwards to upstream DoH servers (with fallback)

proxy-dns: true
proxy-dns-port: {{ cloudflared_port }}
proxy-dns-address: 127.0.0.1

# Upstream DNS-over-HTTPS endpoints (cloudflared round-robins between these)
# Profile: {{ profile }}
proxy-dns-upstream:
{% if profile == 'standard' %}
  # Primary: Cloudflare (fastest, anycast)
  - https://1.1.1.1/dns-query
  - https://1.0.0.1/dns-query
  # Fallback: Mullvad standard (IP to avoid DNS chicken-and-egg)
  - https://194.242.2.2/dns-query
{% else %}
  # Primary: Cloudflare Family (blocks malware + adult content)
  - https://1.1.1.3/dns-query
  - https://1.0.0.3/dns-query
  # Fallback: Mullvad Family (IP to avoid DNS chicken-and-egg)
  - https://194.242.2.6/dns-query
{% endif %}

# Logging
loglevel: warn
